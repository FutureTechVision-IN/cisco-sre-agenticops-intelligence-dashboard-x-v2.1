# Normalize line endings on checkout.
# All text files default to LF so the repo is consistent across platforms.
* text=auto eol=lf
# Shell scripts must always use LF (shebang breaks on CRLF).
*.sh        text eol=lf
*.bash      text eol=lf
# Windows batch / PowerShell files use CRLF as expected by cmd.exe / pwsh.
*.bat       text eol=crlf
*.cmd       text eol=crlf
*.ps1       text eol=crlf
# Source / config files – LF everywhere for consistency.
*.ts        text eol=lf
*.tsx       text eol=lf
*.js        text eol=lf
*.jsx       text eol=lf
*.mjs       text eol=lf
*.cjs       text eol=lf
*.json      text eol=lf
*.yaml      text eol=lf
*.yml       text eol=lf
*.toml      text eol=lf
*.md        text eol=lf
*.txt       text eol=lf
*.html      text eol=lf
*.css       text eol=lf
*.env       text eol=lf
*.env.*     text eol=lf
*.conf      text eol=lf
*.py        text eol=lf
# Binary files – never mangle.
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.webp      binary
*.ico       binary
*.svg       binary
*.woff      binary
*.woff2     binary
*.ttf       binary
*.otf       binary
*.eot       binary
*.pdf       binary
*.zip       binary
*.tar.gz    binary
*.tgz       binary
*.lock      text eol=lf
# ─── Git LFS: Large data files ───────────────────────────────────────────────
# The Vulnerability Tracker CSV is critical for the dashboard and must be
# preserved across all Git operations. LFS stores the actual content externally
# while keeping a pointer in the repo.
data/fn_aug25-feb26.csv filter=lfs diff=lfs merge=lfs -text
data/*.csv filter=lfs diff=lfs merge=lfs -text
