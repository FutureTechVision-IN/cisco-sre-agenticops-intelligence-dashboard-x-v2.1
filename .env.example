# ============================================================================
# SECRETS MANAGEMENT - Environment Configuration Template
# ============================================================================
# Copy this file to .env and fill in your credentials.
# NEVER commit .env to version control.
# Use `npm run secrets:encrypt` to generate .env.encrypted for production.
# ============================================================================

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/cisco_sre_dashboard
SESSION_SECRET=generate-a-strong-random-secret-here
NODE_ENV=production
PORT=5000
FRONTEND_URL=http://localhost:5000

# Redis (optional, for caching)
# REDIS_URL=redis://localhost:6379

# ============================================================================
# CISCO CIRCUIT API KEYS
# ============================================================================
# Format: egai-{env}-{domain}-{accountId}-{purpose}-{timestamp}
CISCO_CIRCUIT_API_KEY=egai-prd-cx-ACCOUNT_ID-summarize-TIMESTAMP
CISCO_CIRCUIT_WORKFLOW_KEY=egai-prd-operations-ACCOUNT_ID-workflow-TIMESTAMP
CISCO_CIRCUIT_ENDPOINT=https://circuit.cisco.com/api/v1

# Cisco OAuth2 Credentials (Base64 encoded client_id:client_secret)
CISCO_OAUTH_TOKEN_URL=https://id.cisco.com/oauth2/default/v1/token
CISCO_OAUTH_CLIENT_SUMMARIZE=BASE64_ENCODED_CLIENT_CREDENTIALS
CISCO_OAUTH_CLIENT_WORKFLOW=BASE64_ENCODED_CLIENT_CREDENTIALS

# ============================================================================
# AZURE OPENAI (ChatGPT Integration)
# ============================================================================
AZURE_OPENAI_API_KEY=your-azure-openai-key
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# ============================================================================
# GOOGLE GEMINI (Multi-modal AI + Voice)
# ============================================================================
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash
GEMINI_VOICE_MODEL=gemini-2.0-flash-live
GEMINI_PROJECT_ID=your-gcp-project-id
GEMINI_LOCATION=us-central1

# ============================================================================
# SNOWFLAKE (Data Warehouse)
# ============================================================================
SNOWFLAKE_ACCOUNT=your-account.snowflakecomputing.com
SNOWFLAKE_USERNAME=your_username
SNOWFLAKE_PASSWORD=your_password
SNOWFLAKE_DATABASE=CISCO_SRE
SNOWFLAKE_SCHEMA=PUBLIC
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_ROLE=ANALYST

# ============================================================================
# LANGCHAIN (AI Orchestration & Tracing)
# ============================================================================
LANGCHAIN_API_KEY=ls__your-langchain-api-key
LANGCHAIN_PROJECT=cisco-sre-dashboard
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# ============================================================================
# SECRETS MANAGEMENT CONFIG
# ============================================================================
SECRETS_ROTATION_DAYS=90
SECRETS_VALIDATION_INTERVAL_MS=3600000
SECRETS_ENCRYPTION_KEY=generate-32-byte-hex-key
