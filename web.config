<?xml version="1.0" encoding="UTF-8"?>
<!--
  IIS web.config for SRE AgenticOps Intelligence Dashboard
  =========================================================
  Deployment: Windows Server 2016/2019/2022 with IIS 10
  Mode:       Reverse proxy (ARR) to Node.js on port 8000
              OR direct static file serving from dist/

  Prerequisites:
    - IIS with Application Request Routing (ARR) 3.0
    - URL Rewrite Module 2.1
    - Node.js 18+ installed on the server
    - The Node.js app is running on localhost:8000

  Two deployment scenarios are supported:
  ─────────────────────────────────────────
  A) REVERSE PROXY (recommended for production):
     IIS listens on port 80/443 and forwards all requests to node build/index.js
     on port 8000. The Node.js server handles both static assets and API routes.
     Place this web.config in the IIS site root (C:\inetpub\wwwroot\dashboard\).

  B) STATIC FILES ONLY (simpler, no Node.js in IIS):
     Run the Node.js server separately; serve only the dist/ folder directly
     from IIS for the static frontend, proxying /api/* to Node on 8000.
     Place this web.config in the dist/ directory.
-->
<configuration>
  <system.webServer>

    <!-- ── MIME Types ──────────────────────────────────────────────────── -->
    <!-- IIS does not serve unknown extensions by default.                  -->
    <!-- These additions ensure modern web assets are served correctly.     -->
    <staticContent>
      <remove fileExtension=".woff"  />
      <remove fileExtension=".woff2" />
      <remove fileExtension=".json"  />
      <remove fileExtension=".mjs"   />
      <remove fileExtension=".webp"  />
      <remove fileExtension=".avif"  />
      <mimeMap fileExtension=".woff"  mimeType="font/woff"               />
      <mimeMap fileExtension=".woff2" mimeType="font/woff2"              />
      <mimeMap fileExtension=".json"  mimeType="application/json"        />
      <mimeMap fileExtension=".mjs"   mimeType="application/javascript"  />
      <mimeMap fileExtension=".webp"  mimeType="image/webp"              />
      <mimeMap fileExtension=".avif"  mimeType="image/avif"              />
    </staticContent>

    <!-- ── Default document ────────────────────────────────────────────── -->
    <defaultDocument>
      <files>
        <clear />
        <add value="index.html" />
      </files>
    </defaultDocument>

    <!-- ── Security Headers ────────────────────────────────────────────── -->
    <!-- These headers are also set by the Node.js server.                  -->
    <!-- In a pure-IIS static deployment, set them here instead.           -->
    <httpProtocol>
      <customHeaders>
        <!-- Prevent clickjacking -->
        <add name="X-Frame-Options"           value="SAMEORIGIN" />
        <!-- Disable MIME-type sniffing -->
        <add name="X-Content-Type-Options"    value="nosniff" />
        <!-- Enable XSS filter in IE/Edge legacy -->
        <add name="X-XSS-Protection"          value="1; mode=block" />
        <!-- HTTPS-only policy (enable only when serving over HTTPS) -->
        <!-- <add name="Strict-Transport-Security" value="max-age=31536000; includeSubDomains" /> -->
        <!-- Referrer policy -->
        <add name="Referrer-Policy"           value="strict-origin-when-cross-origin" />
        <!-- Permissions policy: disable unnecessary browser features -->
        <add name="Permissions-Policy"        value="geolocation=(), camera=(), microphone=(self)" />
        <!-- Remove IIS version disclosure -->
        <remove name="X-Powered-By" />
      </customHeaders>
    </httpProtocol>

    <!-- ── URL Rewrite Rules ────────────────────────────────────────────── -->
    <!-- Requires URL Rewrite Module 2.1 (install via Web Platform Installer) -->
    <rewrite>
      <rules>

        <!-- Rule 1: WebSocket proxy to Node.js (/ws/* → ws://localhost:8000) -->
        <!-- Requires ARR 3.0 with WebSocket proxying enabled                 -->
        <rule name="Proxy WebSocket to Node" stopProcessing="true">
          <match url="^ws/(.*)" />
          <conditions>
            <add input="{HTTP_CONNECTION}" pattern="Upgrade" />
          </conditions>
          <action type="Rewrite"
                  url="http://localhost:8000/ws/{R:1}" />
        </rule>

        <!-- Rule 2: Proxy all /api/* requests to Node.js server             -->
        <rule name="Proxy API to Node" stopProcessing="true">
          <match url="^api/(.*)" />
          <action type="Rewrite"
                  url="http://localhost:8000/api/{R:1}" />
        </rule>

        <!-- Rule 3: Serve existing static files (from dist/) directly       -->
        <rule name="Static Files" stopProcessing="true">
          <match url=".*" />
          <conditions>
            <add input="{REQUEST_FILENAME}" matchType="IsFile" />
          </conditions>
          <action type="None" />
        </rule>

        <!-- Rule 4: SPA fallback — everything else returns index.html       -->
        <!-- This enables React Router / Wouter client-side routing          -->
        <rule name="SPA Fallback to index.html" stopProcessing="true">
          <match url=".*" />
          <conditions>
            <add input="{REQUEST_FILENAME}" matchType="IsFile"      negate="true" />
            <add input="{REQUEST_FILENAME}" matchType="IsDirectory" negate="true" />
          </conditions>
          <action type="Rewrite" url="/index.html" />
        </rule>

      </rules>
    </rewrite>

    <!-- ── Output Caching (static assets) ──────────────────────────────── -->
    <!-- Vite content-hashes asset filenames — cache them aggressively      -->
    <caching>
      <profiles>
        <add extension=".js"    policy="CacheUntilChange" kernelCachePolicy="CacheUntilChange" />
        <add extension=".css"   policy="CacheUntilChange" kernelCachePolicy="CacheUntilChange" />
        <add extension=".woff2" policy="CacheUntilChange" kernelCachePolicy="CacheUntilChange" />
        <add extension=".png"   policy="CacheUntilChange" kernelCachePolicy="CacheUntilChange" />
        <add extension=".svg"   policy="CacheUntilChange" kernelCachePolicy="CacheUntilChange" />
        <add extension=".webp"  policy="CacheUntilChange" kernelCachePolicy="CacheUntilChange" />
      </profiles>
    </caching>

    <!-- ── Static file cache-control headers ───────────────────────────── -->
    <location path="assets">
      <system.webServer>
        <httpProtocol>
          <customHeaders>
            <!-- Vite adds content hashes to filenames → safe to cache forever -->
            <add name="Cache-Control" value="public, max-age=31536000, immutable" />
          </customHeaders>
        </httpProtocol>
      </system.webServer>
    </location>

    <!-- ── Error pages ─────────────────────────────────────────────────── -->
    <httpErrors errorMode="Custom" existingResponse="PassThrough">
      <remove statusCode="404" />
      <error statusCode="404" path="/index.html" responseMode="ExecuteURL" />
    </httpErrors>

    <!-- ── Compression ─────────────────────────────────────────────────── -->
    <urlCompression doStaticCompression="true" doDynamicCompression="true" />

    <!-- ── Request filtering (security hardening) ──────────────────────── -->
    <requestFiltering>
      <!-- Remove server version from headers -->
      <requestLimits maxAllowedContentLength="10485760" /> <!-- 10 MB max upload -->
      <hiddenSegments>
        <add segment="web.config" />
        <add segment=".env" />
        <add segment=".git" />
        <add segment="node_modules" />
        <add segment="backend" />
        <add segment="data" />
      </hiddenSegments>
    </requestFiltering>

  </system.webServer>
</configuration>
