  "name": "sre-agenticops-intelligence-dashboard",
  "version": "2.1.0",
  "type": "module",
  "license": "MIT",
  "homepage": "https://FutureTechVision-IN.github.io/cisco-sre-agenticops-intelligence-dashboard-x-v2.1",
  "repository": {
    "type": "git",
    "url": "https://github.com/FutureTechVision-IN/cisco-sre-agenticops-intelligence-dashboard-x-v2.1.git"
  },
  "scripts": {
    "dev:client": "npx vite dev --port 8000",
    "dev": "cross-env NODE_ENV=development tsx backend/index-dev.ts",
    "build": "npx vite build && npx esbuild backend/index-prod.ts --platform=node --packages=external --bundle --format=esm --outfile=build/index.js",
    "build:prod": "npx vite build && npx esbuild backend/index-prod.ts --platform=node --packages=external --bundle --format=esm --outfile=build/index.js && npm run check",
    "build:gh-pages": "cross-env GITHUB_PAGES=true npx vite build --base=./",
    "start": "cross-env NODE_ENV=production node build/index.js",
    "check": "tsc",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --passWithNoTests",
    "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage --passWithNoTests",
    "lint": "eslint frontend backend --ext .ts,.tsx",
    "qa:startup": "node scripts/qa/startup-check.mjs",
    "qa:visual": "node scripts/qa/light-theme-visual-check.mjs",
    "qa:visual:update": "UPDATE_VISUAL_BASELINE=1 node scripts/qa/light-theme-visual-check.mjs",
    "db:push": "drizzle-kit push",
    "export:static": "tsx scripts/export-static-data.ts",
    "build:static": "cross-env GITHUB_PAGES=true VITE_STATIC_MODE=true npx vite build --base=/pages/bipbabu/cisco-sre-agenticops-intelligence-dashboard-x/",
    "build:github-pages": "npm run export:static && npm run build:static && shx cp -r public/static-data build/public/static-data",
    "preview:static": "cross-env VITE_STATIC_MODE=true npx vite preview --base=/",
    "deploy": "bash scripts/deploy-all-branches.sh full",
    "deploy:sync": "bash scripts/deploy-all-branches.sh sync",
    "deploy:build": "bash scripts/deploy-all-branches.sh build",
    "deploy:gh-pages": "bash scripts/deploy-all-branches.sh deploy",
    "predeploy": "npm run build:gh-pages",
    "preview": "npx vite preview",
    "secrets:encrypt": "node scripts/secrets/encrypt-secrets.mjs",
    "secrets:decrypt": "node scripts/secrets/decrypt-secrets.mjs",
    "secrets:verify": "node -e \"import('./scripts/secrets/load-secrets.mjs').then(()=>console.log('Secrets loaded OK')).catch(e=>{console.error(e.message);process.exit(1);})\""  ,
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:chromium": "playwright test --project=chromium",
    "test:e2e:firefox": "playwright test --project=firefox",
    "test:e2e:webkit": "playwright test --project=webkit",
    "test:e2e:edge": "playwright test --project=edge",
    "test:e2e:cross-platform": "playwright test tests/cross-platform/",
    "test:e2e:compat": "playwright test tests/cross-platform/browser-compat.spec.ts",
    "test:e2e:responsive": "playwright test tests/cross-platform/responsive.spec.ts",
    "test:e2e:performance": "playwright test tests/cross-platform/performance.spec.ts",
    "test:e2e:report": "playwright show-report",
    "compat:check": "node scripts/qa/cross-platform-compat-check.mjs"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "browserslist": [
    "last 2 Chrome versions",
    "last 2 Edge versions",
    "last 2 Firefox versions",
    "last 2 Safari versions",
    "not IE 11",
    "not dead"
  ],
  "notes": "removed framer motion dependency",
